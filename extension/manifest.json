{
  "manifest_version": 3,
  "name": "VibeRef Clipper",
  "version": "1.0",
  "description": "한 클릭으로 디자인 레퍼런스를 VibeRef에 저장하세요.",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://viberef-wheat.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
