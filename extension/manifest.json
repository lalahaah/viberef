{
  "manifest_version": 3,
  "name": "VibeRef Clipper",
  "version": "1.0",
  "description": "Save design references to VibeRef with one click. The ultimate tool for vibe coders.",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://viberef-wheat.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
